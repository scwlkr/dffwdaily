---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getArticles } from '../utils/api';

const articles = await getArticles();
const featuredArticle = articles.length > 0 ? articles[0] : null;
const otherArticles = articles.length > 1 ? articles.slice(1) : [];
---

<Layout title="DFFW Daily - The Local News Engine">
	<Header />
	
	<main class="flex-grow">
		{articles.length === 0 ? (
			<p class="text-center font-serif text-xl py-20 text-gray-500">No news is good news. Check back later.</p>
		) : (
			<div class="flex flex-col gap-12">
				{featuredArticle && (
					<section class="mb-8">
						<ArticleCard 
							id={featuredArticle.id}
							title={featuredArticle.title}
							image_url={featuredArticle.image_url}
							published_at={featuredArticle.published_at}
							snippet={featuredArticle.content.substring(0, 300) + "..."}
						/>
					</section>
				)}
				
				{otherArticles.length > 0 && (
					<section class="grid grid-cols-1 md:grid-cols-2 gap-8 gap-y-12">
						{otherArticles.map((article) => (
							<ArticleCard 
								id={article.id}
								title={article.title}
								image_url={article.image_url}
								published_at={article.published_at}
								snippet={article.content.substring(0, 150) + "..."}
							/>
						))}
					</section>
				)}
			</div>
		)}
	</main>

	<Footer />
</Layout>
