---
const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="py-6 sm:py-10 border-b border-graphite mb-10 text-center flex flex-col items-center">
  <div class="flex justify-between items-end border-b pb-2 mb-8 border-graphite w-full">
    <span class="text-sm font-sans uppercase tracking-widest text-ash">Vol. 1</span>
    <span class="text-sm font-sans uppercase tracking-widest text-ash">{today}</span>
  </div>
  <a href="/" class="inline-block group mb-4">
    <img src="/logo_white.png" alt="DFFW Daily" class="h-16 sm:h-20 w-auto opacity-90 group-hover:opacity-100 transition-opacity" />
  </a>
  <p class="text-lg sm:text-xl font-sans text-ash mt-2 max-w-xl">
    The signal. Never the noise.
  </p>
</header>
